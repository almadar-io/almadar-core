{
  "name": "@almadar/core",
  "version": "2.6.4",
  "description": "Core schema types and definitions for Almadar",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js"
    },
    "./domain-language": {
      "types": "./dist/domain-language/index.d.ts",
      "import": "./dist/domain-language/index.js",
      "require": "./dist/domain-language/index.js"
    },
    "./state-machine": {
      "types": "./dist/state-machine/index.d.ts",
      "import": "./dist/state-machine/index.js",
      "require": "./dist/state-machine/index.js"
    },
    "./builders": {
      "types": "./dist/builders.d.ts",
      "import": "./dist/builders.js",
      "require": "./dist/builders.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@almadar/operators": ">=2.1.3",
    "@almadar/patterns": ">=2.8.7",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "eslint": "10.0.0",
    "@typescript-eslint/parser": "8.56.0",
    "@almadar/eslint-plugin": ">=2.3.0",
    "@types/node": "^22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-core.git",
    "directory": "docs/packages/core"
  },
  "license": "BSL-1.1",
  "keywords": [
    "almadar",
    "orbital",
    "schema",
    "types"
  ],
  "homepage": "https://github.com/almadar-io/almadar#readme"
}
